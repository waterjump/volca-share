- wrapper_class ||= ''
- show_emulation_control ||= false
- emulation_url = patch.user.present? ? emulation_user_patch_path(patch.user.slug, patch.slug) : emulation_patch_path(patch.id)
.wrapper.well.well-sm.patch-holder{
  class: wrapper_class,
  data: {
    patch_id: patch.id.to_s,
    emulation_url: emulation_url,
    emulation_active: 'false'
  }
}
  - if patch.editors_pick?
    .ep
      .ribbon-badge
      .text
        Editor's
        %br
        Pick

  .image-holder
    - if patch.user.present?
      = link_to user_patch_path(patch.user.slug, patch.slug) do
        .image.bass{ class: patch.index_classes }
    - else
      = link_to patch do
        .image.bass{ class: patch.index_classes }

  .patch
    - if patch.secret?
      .lock.glyph{ title: 'Secret' }
    .title
      - if patch.audio_sample_available?
        .speaker{ data: { oembed_url: "/oembed?user_slug=#{patch.user.slug}&slug=#{patch.slug}", toggle: 'modal', target: '#audio-preview-modal' }, title: 'Preview audio' }
          = image_tag 'speaker.svg', class: 'speaker-icon', alt: ''
      - if show_emulation_control
        = button_tag type: 'button', class: 'bass-emulate-toggle', title: 'Emulate patch', aria: { label: "Emulate #{patch.name}", pressed: 'false' }, data: { emulation_url: emulation_url, patch_id: patch.id.to_s, emulation_active: 'false' } do
          %span.bass-emulate-symbol{ 'aria-hidden' => 'true' } ♫
      - if patch.user.present?
        = link_to patch.name, user_patch_path(patch.user.slug, patch.slug)
      - else
        = link_to patch.name, patch_path(patch.id)
    .info
      by
      - if patch.user.present?
        = link_to patch.username, user_path(patch.user.slug), { class: :username }
      - else
        ¯\_(ツ)_/¯
      %span.date= "on #{format_date(patch.created_at)}"
      .icons
        - if current_user.present? && patch.user == current_user
          = link_to edit_patch_path(patch), title: 'Edit patch' do
            = image_tag 'pencil.svg', alt: 'Edit patch', class: 'edit glyph'
          = link_to patch_path(patch), method: :delete, title: 'Delete patch', data: { confirm: 'Are you sure you want to delete that patch?' } do
            = image_tag 'trash.svg', alt: 'Delete patch', class: 'delete glyph'
    .description= patch.notes
    .tags
      - patch.tags.each do |tag|
        = link_to "\##{tag}", tags_show_path(tag: tag), class: :tag
